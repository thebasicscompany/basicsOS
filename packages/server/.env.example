DATABASE_URL=postgresql://postgres:postgres@localhost:5435/crm
BETTER_AUTH_SECRET=generate-with-openssl-rand-base64-32
# Frontend URL (for redirects). Use proxy in dev so VITE_API_URL="" and requests are same-origin.
BETTER_AUTH_URL=http://localhost:5173
BASICOS_API_URL=https://api.basicsos.com
API_KEY_ENCRYPTION_KEY=generate-32-byte-base64-or-hex
# Optional comma-separated previous keys kept for decryption during rotation
API_KEY_ENCRYPTION_KEY_PREVIOUS=
# Optional; defaults to API_KEY_ENCRYPTION_KEY when omitted
API_KEY_HASH_SECRET=
PORT=3001

# NocoDB integration
NOCODB_BASE_URL=http://localhost:8080
NOCODB_API_TOKEN=generate-from-nocodb-ui
NOCODB_BASE_ID=get-from-nocodb-after-connecting-database
NOCODB_WEBHOOK_SECRET=generate-with-openssl-rand-base64-32

# For db:seed (optional - defaults to http://localhost:3001)
# SEED_API_URL=http://localhost:3001
